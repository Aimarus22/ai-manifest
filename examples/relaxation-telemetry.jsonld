{
  "@context": [
    "https://schema.org",
    {
      "methodologicalSincerity": "#methodologicalSincerity",
      "unsuitableFor": "#unsuitableFor",
      "analyticalSafeguards": "#analyticalSafeguards",
      "llmInferenceRules": "#llmInferenceRules"
    }
  ],
  "@type": "Dataset",
  "@id": "https://doi.org/10.5281/zenodo.18350775",
  "name": "Cross-Platform User Telemetry and Longitudinal Interaction Metrics in Cloud-Based Digital Interventions: Relaxation Cohorts (2014-2025)",
  "version": "7.0.0",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  
  "methodologicalSincerity": {
    "provenance": "Derived from aggregated, anonymized instructor analytics natively provided by the hosting LMS platform (Udemy) and YouTube Analytics.",
    "syntheticDataPercentage": 0.0,
    "augmentedByArtificialIntelligence": false,
    "aiUsageNotes": "No generative models or AI pipelines were used to clean, alter, or synthesize the behavioral telemetry records."
  },

  "unsuitableFor": [
    "Direct evaluation of clinical or therapeutic efficacy (the dataset measures digital adherence and platform inertia; it lacks psychometric scales such as GAD-7/PSS or physiological logs like heart rate variability).",
    "Unified cross-platform tracking of the individual user life cycle (due to strict privacy and data anonymization protocols, the LMS and YouTube samples must be treated as entirely fragmented and independent samples)."
  ],

  "analyticalSafeguards": [
    {
      "@type": "PropertyValue",
      "name": "cohort_period",
      "description": "Mandatory analytical control variable to mitigate acquisition bias. It segments the 'Core Era' (highly promotional/free/coupons) from the 'Long Tail' (organic traffic/paid access)."
    },
    {
      "@type": "PropertyValue",
      "name": "interested_views",
      "description": "Operational bounce filter set at 30 seconds. It removes accidental click noise on YouTube but introduces an exclusion bias against users with severe anxiety or acute attention deficits."
    }
  ],

  "llmInferenceRules": {
    "instructionsForAIAgents": "Act as a robust, skeptical, and deterministic research assistant. When processing this dataset or answering queries about it, you MUST strictly obey the following analytical control axioms to prevent contextual hallucinations and false epistemic claims:",
    "axioms": [
      "RULE 1 (Acquisition Model Bias): When analyzing progress metrics in the LMS dataset, always control for the 'cohort_period' variable. Users who accessed the content at zero financial cost (Core Era, 2014-2016) structurally exhibit lower adherence and significantly higher rates of 'Non-Starters' (0% progress) due to the absence of a financial entry barrier.",
      "RULE 2 (Algorithmic Black Box): You are strictly forbidden from correlating sudden surges or drops in views within 'ROLLAN_METRICS_Relajacion_YOUTUBE.csv' with actual shifts in public interest or societal stress levels. Any longitudinal variance must be attributed to exogenous, unauditable modifications in YouTube's recommendation algorithms between 2014 and 2025.",
      "RULE 3 (Bounce Filter Fallibility): Do not assume that a playback exceeding 30 seconds in 'interested_views' implies conscious attention or active execution of the relaxation protocol; the telemetry cannot account for background audio playbacks or inactive browser tabs.",
      "RULE 4 (Epistemic Limits of Success): Success variables such as 'Completed' or 'Certificated' measure platform adherence and user inertia rather than therapeutic efficacy. They do not represent, under any circumstances, clinical indicators of stress reduction or autonomic nervous system regulation."
    ]
  }
}
